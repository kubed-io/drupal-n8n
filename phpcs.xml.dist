<?xml version="1.0" encoding="UTF-8"?>
<!--
  Drupal's own coding standard, via drupal/coder. This is not a house style we
  invented — it is what drupal.org enforces, and CONTRIBUTING.md's first principle
  is to do things the Drupal way.

  DrupalPractice is included on purpose: it catches the Drupal-specific mistakes a
  generic PHP linter cannot see (t() misuse, \Drupal:: calls where injection
  belongs, etc.), which is exactly the class of bug an AI-written diff produces.
-->
<ruleset name="n8n">
  <description>Drupal coding standards for the n8n module.</description>

  <file>src</file>
  <file>modules</file>
  <file>tests</file>

  <exclude-pattern>*/vendor/*</exclude-pattern>
  <exclude-pattern>*/node_modules/*</exclude-pattern>

  <arg name="extensions" value="php,module,inc,install,test,profile,theme,info,yml"/>
  <arg name="colors"/>
  <arg value="sp"/>

  <rule ref="Drupal"/>
  <rule ref="DrupalPractice"/>

  <!--
    Known, declared debt: Drupal.Files.LineLength.TooLong fires across this repo
    because the comments explain *why* the code is the way it is, and that prose
    runs past 80 characters. CI reports these but does not gate on them; see the
    ignore_warnings_on_exit runtime flag in quality.yml.

    This is a licence to keep existing comments, NOT to write new long ones. Wrap
    at 80. The rule is deliberately left ON so the count stays visible and can be
    paid down, rather than excluded and forgotten.

    Note for editors: XML comments cannot contain a double hyphen, so CLI flags
    are named in prose here rather than written out. phpcs rejects the whole
    ruleset with exit 16 if you forget.
  -->
</ruleset>
